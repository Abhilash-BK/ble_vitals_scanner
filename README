## 🧪 Testing with BLE Simulator

### Python BLE Peripheral Simulator

```python
# ble_simulator.py
import asyncio
import random
from bleak import BleakGATTCharacteristic, BleakGATTServiceCollection
from bleak.backends.characteristic import GattCharacteristicsFlags
from bless import (
    BlessServer,
    BlessGATTCharacteristic,
    GATTCharacteristicProperties,
    GATTAttributePermissions
)

# Service and Characteristic UUIDs
VITALS_SERVICE_UUID = "0000180d-0000-1000-8000-00805f9b34fb"
HEART_RATE_CHAR_UUID = "00002a37-0000-1000-8000-00805f9b34fb"
TEMPERATURE_CHAR_UUID = "00002a1c-0000-1000-8000-00805f9b34fb"

class VitalsSimulator:
    def __init__(self):
        self.server = BlessServer(name="BLE Vitals Simulator")
        self.heart_rate = 75
        self.temperature = 370  # 37.0°C (transmitted as 10x)
        
    async def setup(self):
        # Add Health Vitals Service
        await self.server.add_new_service(VITALS_SERVICE_UUID)
        
        # Heart Rate Characteristic
        await self.server.add_new_characteristic(
            VITALS_SERVICE_UUID,
            HEART_RATE_CHAR_UUID,
            GATTCharacteristicProperties.read | GATTCharacteristicProperties.notify,
            None,
            GATTAttributePermissions.readable
        )
        
        # Temperature Characteristic
        await self.server.add_new_characteristic(
            VITALS_SERVICE_UUID,
            TEMPERATURE_CHAR_UUID,
            GATTCharacteristicProperties.read | GATTCharacteristicProperties.notify,
            None,
            GATTAttributePermissions.readable
        )
        
    async def simulate_vitals(self):
        while True:
            # Simulate realistic heart rate (60-100 bpm)
            self.heart_rate = max(60, min(100, self.heart_rate + random.randint(-2, 2)))
            
            # Simulate temperature (36.0-38.0°C)
            self.temperature = max(360, min(380, self.temperature + random.randint(-1, 1)))
            
            # Update characteristics
            hr_data = bytes([0, self.heart_rate])  # Format: [flags, heart_rate]
            temp_data = bytes([
                self.temperature & 0xFF,
                (self.temperature >> 8) & 0xFF
            ])
            
            self.server.update_value(VITALS_SERVICE_UUID, HEART_RATE_CHAR_UUID, hr_data)
            self.server.update_value(VITALS_SERVICE_UUID, TEMPERATURE_CHAR_UUID, temp_data)
            
            await asyncio.sleep(1)  # Update every second
            
    async def run(self):
        await self.setup()
        await self.server.start()
        print("BLE Vitals Simulator started!")
        print(f"Service UUID: {VITALS_SERVICE_UUID}")
        print(f"Heart Rate UUID: {HEART_RATE_CHAR_UUID}")
        print(f"Temperature UUID: {TEMPERATURE_CHAR_UUID}")
        
        await self.simulate_vitals()

if __name__ == "__main__":
    simulator = VitalsSimulator()
    asyncio.run(simulator.run())
```

### Running the Simulator
```bash
pip install bleak bless
python ble_simulator.py
```

