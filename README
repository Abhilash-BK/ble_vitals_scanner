## 🔧 Usage of flutter_reactive_ble

### 1. **Initialization**
```dart
final _ble = FlutterReactiveBle();

void initialize() {
  _ble.statusStream.listen((status) {
    // Handle BLE status changes
    _bleStatus = status;
    notifyListeners();
  });
}
```

### 2. **Device Scanning**
```dart
void startScan() {
  _scanSubscription = _ble.scanForDevices(
    withServices: [],
    scanMode: ScanMode.lowLatency,
  ).listen(
    (device) {
      // Add discovered devices to list
      if (!_discoveredDevices.any((d) => d.id == device.id)) {
        _discoveredDevices.add(device);
        notifyListeners();
      }
    },
    onError: (error) {
      // Handle scan errors
    },
  );
}
```

### 3. **Device Connection**
```dart
void connectToDevice(String deviceId) {
  _connectionSubscription = _ble.connectToDevice(
    id: deviceId,
    connectionTimeout: const Duration(seconds: 30),
  ).listen(
    (connectionState) {
      _deviceConnectionState = connectionState.connectionState;
      
      if (connectionState.connectionState == DeviceConnectionState.connected) {
        _discoverServices(deviceId);
      }
      notifyListeners();
    },
    onError: (error) {
      // Handle connection errors
      if (_autoReconnect) {
        _attemptReconnection(deviceId);
      }
    },
  );
}
```

### 4. **Service Discovery**
```dart
Future<void> _discoverServices(String deviceId) async {
  try {
    _services = await _ble.discoverServices(deviceId);
    notifyListeners();
  } catch (e) {
    // Handle discovery errors
  }
}
```

### 5. **Characteristic Subscription**
```dart
void subscribeToCharacteristic(QualifiedCharacteristic characteristic) {
  _characteristicSubscription = _ble.subscribeToCharacteristic(characteristic).listen(
    (data) {
      // Process incoming data
      _processVitalData(data);
      notifyListeners();
    },
    onError: (error) {
      // Handle subscription errors
    },
  );
}
```

### 6. **Data Processing**
```dart
void _processVitalData(List<int> data) {
  if (data.isEmpty) return;
  
  // Example: Parse heart rate data (first byte)
  int heartRate = data[0];
  
  // Example: Parse temperature (bytes 1-2, little-endian)
  double temperature = (data[1] | (data[2] << 8)) / 10.0;
  
  // Update vital data model
  _vitalData.add(VitalDataModel(
    timestamp: DateTime.now(),
    heartRate: heartRate,
    temperature: temperature,
    // ... other vitals
  ));
}
```

### 7. **Disconnection & Cleanup**
```dart
void disconnect() {
  _characteristicSubscription?.cancel();
  _connectionSubscription?.cancel();
  _scanSubscription?.cancel();
  
  _discoveredDevices.clear();
  _services.clear();
  notifyListeners();
}
```

